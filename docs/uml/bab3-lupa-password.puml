@startuml bab3-lupa-password
title Activity Diagram - Lupa Password

|Pengguna|
start
:Memilih menu "Lupa Password";
:Memasukkan alamat email;

|Sistem|
if (Email terdaftar?) then (tidak)
  :Menampilkan pesan kesalahan;
  stop
else (ya)
  :Mengirim tautan reset password\nke email pengguna;
endif

|Pengguna|
:Membuka tautan dari email;
:Memasukkan password baru\ndan konfirmasinya;

|Sistem|
if (Tautan masih berlaku dan\npassword baru memenuhi syarat?) then (tidak)
  :Menampilkan pesan kesalahan;
  stop
else (ya)
  :Memperbarui password pengguna;
  :Mengarahkan ke halaman login;
endif
stop

@enduml
