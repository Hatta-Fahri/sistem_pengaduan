@startuml activity-lupa-password
title Activity Diagram - Lupa Password (Reset Password)

|Pengguna|
start
:Klik tautan "Lupa Password"\npada halaman Login;
:Isi alamat email;

|Sistem|
if (Email terdaftar &\nlink berhasil dikirim?) then (tidak)
  :Tampilkan pesan error\npada form;
  stop
else (ya)
  :Buat token reset\n(simpan ke password_reset_tokens);
  :Kirim email berisi link reset\n(token + email);
  :Tampilkan pesan\n"Link reset telah dikirim";
endif

|Pengguna|
:Klik link reset password di email;

|Sistem|
:Tampilkan form reset password\n(token & email terisi otomatis);

|Pengguna|
:Isi password baru + konfirmasi;

|Sistem|
if (Token valid, belum kedaluwarsa,\n& password sesuai kebijakan?) then (tidak)
  :Tampilkan pesan error\n(token tidak valid/kedaluwarsa\natau password tidak sesuai);
  stop
else (ya)
  :Update password (hash baru)\n+ reset remember_token;
  :Redirect ke halaman Login\ndengan status berhasil;
endif
stop

@enduml
